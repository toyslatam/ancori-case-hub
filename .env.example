# Copia a .env.local y completa con tu proyecto Supabase.

# App (Vite) — Settings → API
VITE_SUPABASE_URL=https://jyqdfjonikorlwmjepgd.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key

# QuickBooks OAuth: los secretos viven en Supabase Dashboard → Edge Functions → Secrets.
# En Intuit Developer, Redirect URI debe coincidir exactamente con:
#   https://<REF>.supabase.co/functions/v1/qbo-oauth-callback
# QBO_ALLOWED_REDIRECT_PREFIXES (mismo Dashboard): orígenes permitidos para volver a la app, ej:
#   http://localhost:5173,https://tu-dominio.com

# Push App → QBO al guardar/borrar sociedad (mismo valor que QBO_SOCIETY_PUSH_SECRET o QBO_CRON_SECRET en Supabase).
# Cualquiera con el bundle puede verlo: solo entornos de confianza. Ver docs/quickbooks-webhooks-setup.md
# VITE_QBO_SOCIETY_PUSH_SECRET=

# Opcional: seed SQL (npm run seed:db). Cualquiera de estas nombres sirve:
# DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# SUPABASE_DATABASE_URL=...
