# Copia a .env.local (no versionar) para probar funciones en local, ej.:
#   npx supabase functions serve qbo-oauth-start --env-file supabase/functions/.env.local

SUPABASE_URL=https://TU_REF.supabase.co
SUPABASE_ANON_KEY=tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_CRON_SECRET=genera_un_secreto_largo_aleatorio

# Mismo valor que VITE_FUNCTION_SECRET en la app (qbo-create-invoice, qbo-invoice-pdf-sync).
# FUNCTION_SECRET=

# AgileCheck: OAuth/password grant + consulta de cumplimiento.
# No versionar usuario/password reales. Configurarlos como Supabase secrets.
# Mismo HOST en TOKEN_URL y API_BASE. Producción (ejemplo):
# AGILECHECK_TOKEN_URL=https://app.agilecheck.io/HubQueryEngine_agilecheck/api/oauth2/token
# AGILECHECK_API_BASE=https://app.agilecheck.io/HubQueryEngine_agilecheck
# Entorno PRUEBAS (Swagger pruebas.agilecheck.io) — si app.agilecheck.io da ENOTFOUND en tu red, probá:
# AGILECHECK_TOKEN_URL=https://pruebas.agilecheck.io/HubQueryEngine_agilecheck/api/oauth2/token
# AGILECHECK_API_BASE=https://pruebas.agilecheck.io/HubQueryEngine_agilecheck
# AGILECHECK_USERNAME=
# AGILECHECK_PASSWORD=
# AGILECHECK_GRANT_TYPE=password
# Opcional: override del path (por defecto la función usa api/Consulta/Buscar).
# AGILECHECK_QUERY_PATH=api/Consulta/Buscar
# IDs de listas restrictivas en TU tenant (separados por coma). Salen de GET /api/List/GetListas en Swagger.
# Si no se define, la función intenta llamar a GetListas y extraer ids del JSON (puede fallar según forma de respuesta).
# AGILECHECK_LISTA_IDS=1,2,8
# Filtro país opcional (0 = sin país; ver modelo ConsultaIndividualDTOIN).
# AGILECHECK_PAIS_ID=0
# AGILECHECK_PAIS=
# Modo de consulta Hub (entero; por defecto 0).
# AGILECHECK_QUERY_MODE=0
# AGILECHECK_DB=

# Sincronizar cliente Plataforma Ancori → AgileCheck (POST/PUT /api/Cliente). Obligatorio el id de producto/servicio de SU empresa (Swagger ProductoOfrecidoPorEmpresa / GetProductoOfrecidoPorEmpresa).
# AGILECHECK_PRODUCTO_TOMADO_ID=1
# Opcional: catálogo tipo identificación (default 1), género persona natural (default 1), país residencia en modelo Cliente:
# AGILECHECK_TIPO_IDENTIFICACION_ID=1
# AGILECHECK_GENERO_PERSONA_NATURAL_ID=1
# AGILECHECK_CLIENTE_PAIS_RESIDENCIA_ID=

# Opcional (recomendado fuera de EE.UU.): Ids de TaxCode en QuickBooks para cada línea de factura.
# Si no se definen, qbo-create-invoice consulta TaxCode en QBO e intenta inferir exento vs gravado (ITBMS).
# Ver en QBO: Configuración → Impuestos, o query API: SELECT * FROM TaxCode WHERE Active = true
# QBO_TAX_CODE_LINE_TAXABLE=
# QBO_TAX_CODE_LINE_EXEMPT=

# Opcional: Id del TaxRate (no TaxCode) de ITBMS 7% en QBO. Útil si la API no infiere la tasa.
# Query: SELECT * FROM TaxRate WHERE Active = true
# QBO_TAX_RATE_ITBMS=

# Opcional: por defecto false. Usar true solo si QBO requiere TxnTaxDetail + TaxLine explícito.
# Para true, configura QBO_TAX_RATE_ITBMS con el Id exacto del TaxRate de ITBMS en QBO.
# QBO_INVOICE_TXN_TAX_DETAIL=false

# Opcional: por defecto false porque QuickBooks tiene "Custom transaction numbers" activo.
# Si false, qbo-create-invoice reserva un DocNumber correlativo en Supabase y lo envía a QBO.
# Si true, NO se envía DocNumber y QBO debe asignar su correlativo automáticamente.
# QBO_INVOICE_USE_QBO_AUTONUMBER=false

# Opcional: timeout (ms) para llamadas a QuickBooks desde la Edge Function.
# Si QuickBooks tarda más, la función devuelve 504 y la UI no queda cargando.
# QBO_FETCH_TIMEOUT_MS=45000

# Opcional: mismo valor que VITE_QBO_SOCIETY_PUSH_SECRET en la app (o reutiliza QBO_CRON_SECRET).
# QBO_SOCIETY_PUSH_SECRET=

# Verifier Token del portal Intuit → Webhooks (firma HMAC del cuerpo).
# INTUIT_WEBHOOK_VERIFIER_TOKEN=

# UUID de un cliente en public.clients: sociedades creadas desde QBO (webhook) quedan con este client_id.
# QBO_WEBHOOK_DEFAULT_CLIENT_ID=

# Debe ser idéntico a la Redirect URI registrada en Intuit (callback de esta función):
QBO_REDIRECT_URI=https://TU_REF.supabase.co/functions/v1/qbo-oauth-callback

# Orígenes desde los que se permite redirect_to en qbo-oauth-start (sin barra final):
QBO_ALLOWED_REDIRECT_PREFIXES=http://localhost:5173
